/**
 * @brief  PDO閸氼垰濮╂导鐑樻箛閻㈠灚婧€
 * 
 * @param[in]  nodeId 鐠佹儳顦琁D
 * 
 * @note  閺?
 * 
 */
/**
 * @brief 濮濓絽绱￠惃?RPDO 閸氼垰濮╁ù浣衡柤閵? * @param[in] nodeId 閼哄倻鍋?ID閵? * @note 閸氼垰濮╅梼鑸殿唽娴ｈ法鏁?RPDO 娑撳褰?0x06閵?x07閵?x0F閿? *       娑擃參妫跨粚鎸庡絻鐏忔垿鍣?SDO 閸ョ偠顕扮涵顔款吇閻樿埖鈧緤绱辨潻鎰攽閺堢喐甯堕崚璺虹摟閸ュ搫鐣炬穱婵囧瘮 0x0F閵? */
void PDO_StartServoMotor(uint8_t nodeId)
{
    uint32_t runtimeCounter = 0U;

    FillPDOData(&pdodata, SERVO_MODE_VELOCITY, CTRL_WORD_SHUTDOWN, 1000000);

    clearRPDO1Mapping(nodeId);
    configureRPDO1Mapping(nodeId);
    SetRPDO1MappingNumber(nodeId);
    configureRPDO1Communication(nodeId);
    sendNMTStartNodeCommand(nodeId);
    SDK_DelayAtLeastUs(50000U, SDK_DEVICE_MAXIMUM_CPU_CLOCK_FREQUENCY);

    SendRPDORepeated(nodeId, &pdodata, 8U, PDO_STARTUP_PERIOD_US);
    VerifyServoStateBySDO(nodeId, "After shutdown", false);

    FillPDOData(&pdodata, SERVO_MODE_VELOCITY, CTRL_WORD_SWITCH_ON, 1000000);
    SendRPDORepeated(nodeId, &pdodata, 8U, PDO_STARTUP_PERIOD_US);
    VerifyServoStateBySDO(nodeId, "After switch on", false);

    FillPDOData(&pdodata, SERVO_MODE_VELOCITY, CTRL_WORD_ENABLE_OPERATION, 1000000);
    SendRPDORepeated(nodeId, &pdodata, 12U, PDO_STARTUP_PERIOD_US);
    VerifyServoStateBySDO(nodeId, "After enable operation", true);

    if (!IsServoOperationEnabled(ReadStatusWord(nodeId)))
    {
        SendRPDORepeated(nodeId, &pdodata, 12U, PDO_STARTUP_PERIOD_US);
        VerifyServoStateBySDO(nodeId, "Retry enable operation", true);
    }

    while (true)
    {
        sendPDOData(nodeId, &pdodata);
        SDK_DelayAtLeastUs(PDO_STARTUP_PERIOD_US, SDK_DEVICE_MAXIMUM_CPU_CLOCK_FREQUENCY);

        runtimeCounter++;
        if (runtimeCounter >= PDO_RUNTIME_FEEDBACK_CYCLES)
        {
            runtimeCounter = 0U;
            LogPDOFeedback(nodeId, "Runtime feedback");
        }
    }

    static unsigned char value = 0;
    //闁板秶鐤哛PDO閺佺増宓?
    pdodata.mode = 0x03;
    pdodata.ctrl = 0x06;
    pdodata.speed = 1000000;

    // 闁板秶鐤哛PDO閺勭姴鐨犻崪瀛∕T閸氼垰濮?
    clearRPDO1Mapping(nodeId);
    configureRPDO1Mapping(nodeId);
    SetRPDO1MappingNumber(nodeId);
    sendNMTStartNodeCommand(nodeId);

    /* 娑撹鎯婇悳顖ょ窗閸涖劍婀￠幀褍褰傞柅?PDO 閺佺増宓?*/
    while (true)
    {
        value ++;
        if(value == 1)
        {
            pdodata.ctrl = 0x06;
        }
        else if(value == 80)
        {
            pdodata.ctrl = 0x07;
        }
        else if(value == 160)
        { 
            pdodata.ctrl = 0x0F;
        }
        else if(value >= 165)
        {
            value = 165;
        }

        sendPDOData(nodeId, &pdodata);             // 閸欐垿鈧?PDO 閺佺増宓?(ID 0x201, 閸ュ搫鐣鹃弫鐗堝祦)
        
        /* 閺嶈宓侀棁鈧Ч鍌濐啎鐎规艾褰傞柅浣告噯閺堢噦绱濇笟瀣洤濮?8ms 閸欐垿鈧椒绔村▎?*/
        SDK_DelayAtLeastUs(8000, SDK_DEVICE_MAXIMUM_CPU_CLOCK_FREQUENCY);
    }
}

