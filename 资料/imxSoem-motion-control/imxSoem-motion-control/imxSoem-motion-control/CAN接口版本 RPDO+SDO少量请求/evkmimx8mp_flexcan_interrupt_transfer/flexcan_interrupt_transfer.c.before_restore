}

/**
 * @brief 閸氼垰濮?CAN 閹恒儲鏁归敍鍫ユ姜闂冭顢ｉ敍澶涚礉闁板秶鐤?MB 娑撶儤瀵氱€?ID
 * @param id 閺堢喐婀滈幒銉︽暪閻?ID閿涘牊鐖ｉ崙鍡樼壐瀵骏绱?
 */
/**
 * @brief 閸氼垰濮╂稉鈧▎?CAN 閹恒儲鏁归妴? * @param[in] id 閺堢喐婀滈幒銉︽暪閻ㄥ嫭鐖ｉ崙鍡楁姎 ID閵? * @note 娴兼岸鍣搁弬浼村帳缂冾喗甯撮弨鍫曞仏缁犳唻绱濋崣顏呭复閺€鎯邦嚉 ID 閻ㄥ嫭濮ら弬鍥モ偓? */
void CAN_StartReceive(uint32_t id)
{
    /* 娑擃厽顒涜ぐ鎾冲閸欘垵鍏樺锝呮躬鏉╂稖顢戦惃鍕复閺€璁圭礄闁藉牆顕崥灞肩娑?MB閿?*/
    FLEXCAN_TransferAbortReceive(EXAMPLE_CAN, &flexcanHandle, RX_MESSAGE_BUFFER_NUM);

    /* 閺囧瓨鏌婇崗銊ョ湰閹衡晝鐖滈敍姘矌閸忎浇顔忛崠褰掑帳鐠?ID 閻ㄥ嫭濮ら弬鍥箻閸?*/
    FLEXCAN_SetRxMbGlobalMask(EXAMPLE_CAN, FLEXCAN_RX_MB_STD_MASK(id, 0, 0));

    /* 闁插秵鏌婇柊宥囩枂 Rx Message Buffer */
    mbConfig.format = kFLEXCAN_FrameFormatStandard;
    mbConfig.type   = kFLEXCAN_FrameTypeData;
    mbConfig.id     = FLEXCAN_ID_STD(id);
    FLEXCAN_SetRxMbConfig(EXAMPLE_CAN, RX_MESSAGE_BUFFER_NUM, &mbConfig, true);

    /* 閸氼垰濮╅棃鐐烘▎婵夌偞甯撮弨?*/
    rxXfer.mbIdx = (uint8_t)RX_MESSAGE_BUFFER_NUM;
    rxXfer.frame = &frame;
    (void)FLEXCAN_TransferReceiveNonBlocking(EXAMPLE_CAN, &flexcanHandle, &rxXfer);
}

/**
 * @brief 缁涘绶熼幒銉︽暪鐎瑰本鍨氶敍灞借嫙閹垫挸宓冮幒銉︽暪閸掓壆娈戠敮褌淇婇幁?
 */
