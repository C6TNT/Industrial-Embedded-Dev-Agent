/**
 * @brief 閸欐垿鈧椒绔寸敮褎鐖ｉ崙?CAN 閹躲儲鏋冮妴? * @param[in] id 閺嶅洤鍣敮?ID閵? * @param[in] data 64 娴ｅ秵濮ら弬鍥ㄦ殶閹诡喓鈧? * @param[in] length 閺堫剚顐奸崣鎴︹偓浣烘畱閺佺増宓侀梹鍨閿涘苯宕熸担宥勮礋鐎涙濡妴? * @note 閺堫剙鍤遍弫棰佺窗闂冭顢ｇ粵澶婄窡閸欐垿鈧礁鐣幋鎰┾偓? */
void CAN_Send(uint32_t id, uint64_t data, uint8_t length)
{
    frame.id     = FLEXCAN_ID_STD(id);
    txXfer.mbIdx = (uint8_t)TX_MESSAGE_BUFFER_NUM;
    frame.length = length;           // 閻㈣精鐨熼悽銊ㄢ偓鍛瘹鐎规岸鏆辨惔?
    frame.type   = 0;                // 閺佺増宓佺敮?
    frame.format = 0;                // 閺嶅洤鍣弽鐓庣础
    frame.data   = data;             // 婵″倹鐏?length < 8閿涘矂鐝担宥嗘殶閹诡喗妫ら弫?
    txXfer.frame = &frame;
    (void)FLEXCAN_TransferSendNonBlocking(EXAMPLE_CAN, &flexcanHandle, &txXfer);
    while (!txComplete);
    txComplete = false;
}

/**
 * @brief 閸欐垼鎹ｆ稉鈧▎?SDO 鐠囨槒顕Ч鍌樷偓? * @param[in] nodeId 閼哄倻鍋?ID閵? * @param[in] index 鐎电钖勭槐銏犵穿閵? * @param[in] subindex 鐎涙劗鍌ㄥ鏇樷偓? * @return 閹?32 娴ｅ秵妫ょ粭锕€褰块弫鎷屝掗弸鎰畱鏉╂柨娲栭崐绗衡偓? */
uint32_t SDO_ReadU32(uint8_t nodeId, uint16_t index, uint8_t subindex)
{
    uint64_t value;

    value = ((uint64_t)subindex) |
            ((uint64_t)((index >> 8) & 0xFF) << 8) |
            ((uint64_t)(index & 0xFF) << 16) |
            ((uint64_t)0x40 << 24);

    CAN_StartReceive(0x580 + nodeId);
    CAN_Send(0x600 + nodeId, value, 8);
    CAN_WaitReceive();

    return ((uint32_t)frame.dataByte7) |
           ((uint32_t)frame.dataByte6 << 8) |
           ((uint32_t)frame.dataByte5 << 16) |
           ((uint32_t)frame.dataByte4 << 24);
}

