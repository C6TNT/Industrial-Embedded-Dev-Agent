    LOG_INFO("Rx MB ID: 0x%3x, Rx MB data: 0x%02X%02X%02X%02X%02X%02X%02X%02X, Time stamp: %d\r\n",
             (frame.id >> CAN_ID_STD_SHIFT),  
              frame.dataByte3,  frame.dataByte2,  frame.dataByte1,  frame.dataByte0,
              frame.dataByte7,  frame.dataByte6,  frame.dataByte5,  frame.dataByte4, frame.timestamp);
}


/**
 * @brief SDO閹躲儲鏋冮崣鎴炴暪閸戣姤鏆?
 *
 * @param[in] nodeId 鐠佹儳顦琁D
 * @param[in] index 鐎电钖勭槐銏犵穿
 * @param[in] subindex 鐎电钖勭€涙劗鍌ㄥ?
 * @param[in] data 閺佺増宓?
 * @param[in] dataSize 閺佺増宓佺€涙濡梹鍨
 * 
 * @return 閺?
 * 
 * @note 閺佺増宓佺€涙濡梹鍨閸欘亣鍏橀柅澶嬪1 2 4 
 *       鐎电钖勭槐銏犵穿2鐎涙濡?
 *       鐎电钖勭€涙劗鍌ㄥ?鐎涙濡?
 */
/**
 * @brief 閸欐垼鎹ｆ稉鈧▎?SDO 閸愭瑨顕Ч鍌樷偓? * @param[in] nodeId 閼哄倻鍋?ID閵? * @param[in] index 鐎电钖勭槐銏犵穿閵? * @param[in] subindex 鐎涙劗鍌ㄥ鏇樷偓? * @param[in] data 鐟曚礁鍟撻崗銉ф畱閺佺増宓侀妴? * @param[in] dataSize 閺佺増宓侀梹鍨閿涘苯褰ч弨顖涘瘮 1閵?閵? 鐎涙濡妴? */
void SDO_Write(uint8_t nodeId, uint16_t index, uint8_t subindex, uint32_t data, uint8_t dataSize)
{
    uint8_t cs;
    uint64_t value;
    // 閺嶈宓侀弫鐗堝祦闂€鍨闁瀚ㄩ崨鎴掓姢閻礁鑻熼幋顏呮焽閺佺増宓?
    if (dataSize == 1) {
        cs = 0x2F;
        data &= 0xFF;          // 娴犲懍绻氶悾娆庣秵8娴?
    } else if (dataSize == 2) {
        cs = 0x2B;
        data &= 0xFFFF;        // 娴犲懍绻氶悾娆庣秵16娴?
    } else if (dataSize == 4) {
        cs = 0x23;
        // data 閸忋劑鍎撮張澶嬫櫏閿涘本妫ら棁鈧幋顏呮焽
    } else {
        // 婢跺嫮鎮婂鍌氱埗闂€鍨閿涘牆褰查弽瑙勫祦闂団偓鐟曚焦鍧婇崝鐘绘晩鐠囶垰顦╅悶鍡礉濮濄倕顦╂妯款吇娴ｈ法鏁?鐎涙濡崨鎴掓姢閿?
        cs = 0x23;
    }

    // 閺嬪嫰鈧?64 娴?CAN 閺佺増宓侀崺鐕傜礄鐏忓繒顏惔蹇ョ礆閿?
    // 鐎涙濡?~7閿涙碍鏆熼幑顔肩毈缁旑垽绱檇ata 閻?4 娑擃亜鐡ч懞鍌︾礉閺堫亞鏁ょ€涙濡懛顏勫З娑?閿?
    // 鐎涙濡?   閿涙艾鎳℃禒銈囩垳 cs
    // 鐎涙濡?   閿涙氨鍌ㄥ鏇㈢彯鐎涙濡?((index >> 8) & 0xFF)
    // 鐎涙濡?   閿涙氨鍌ㄥ鏇氱秵鐎涙濡?(index & 0xFF)
    // 鐎涙濡?   閿涙艾鐡欑槐銏犵穿 subindex
    value = ((uint64_t)subindex) |
            ((uint64_t)((index >> 8) & 0xFF) << 8) |
            ((uint64_t)(index & 0xFF) << 16) |
            ((uint64_t)cs << 24) |
            ((uint64_t)((data >> 24) & 0xFF) << 32) |
            ((uint64_t)((data >> 16) & 0xFF) << 40) |
            ((uint64_t)((data >> 8)  & 0xFF) << 48) |
            ((uint64_t)(data & 0xFF) << 56);

    // 閸氼垰濮╅幒銉︽暪 SDO 閸濆秴绨查敍鍫滅矤閼哄倻鍋ｉ崷鏉挎絻 0x580 + nodeId閿?
    CAN_StartReceive(0x580 + nodeId);

    // 閸欐垿鈧?SDO 鐠囬攱鐪伴敍鍫濆煂閼哄倻鍋ｉ崷鏉挎絻 0x600 + nodeId閿?
    CAN_Send(0x600 + nodeId, value, 8);

    // 缁涘绶熼崫宥呯安閿涘牊鏁為幇蹇ョ窗鐎圭偤妾担璺ㄦ暏娑擃厼缂撶拋顔煎閸忋儴绉撮弮鑸垫簚閸掕绱?
    CAN_WaitReceive();
}

