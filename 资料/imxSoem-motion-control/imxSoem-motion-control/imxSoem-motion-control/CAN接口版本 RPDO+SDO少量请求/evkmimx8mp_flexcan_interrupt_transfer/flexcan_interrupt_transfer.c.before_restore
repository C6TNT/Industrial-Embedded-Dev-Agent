/**
 * @brief 閸掋倖鏌囨す鍗炲З閸ｃ劍妲搁崥锕€鍑℃潻娑樺弳 Operation Enabled閵? * @param[in] statusWord 0x6041 閻樿埖鈧礁鐡ч妴? * @return true 鐞涖劎銇氬鑼剁箻閸忋儰濞囬懗鍊熺箥鐞涘本鈧降鈧? */
static bool IsServoOperationEnabled(uint16_t statusWord)
{
    return (statusWord & STATUS_WORD_OPERATION_ENABLED_MASK) == STATUS_WORD_OPERATION_ENABLED_VALUE;
}

/**
 * @brief 閸ョ偠顕?0x6041 閻樿埖鈧礁鐡ч妴? * @param[in] nodeId 閼哄倻鍋?ID閵? * @return 16 娴ｅ秶濮搁幀浣哥摟閵? */
static uint16_t ReadStatusWord(uint8_t nodeId)
{
    return (uint16_t)(SDO_ReadU32(nodeId, 0x6041, 0x00) & 0xFFFFU);
}

/**
 * @brief 闁俺绻冪亸鎴﹀櫤 SDO 閸ョ偠顕扮涵顔款吇瑜版挸澧犳す鍗炲З閻樿埖鈧降鈧? * @param[in] nodeId 閼哄倻鍋?ID閵? * @param[in] tag 瑜版挸澧犻梼鑸殿唽閺嶅洨顒烽敍宀€鏁ゆ禍搴㈡）韫囨澧﹂崡鑸偓? * @param[in] expectEnabled 閺勵垰鎯侀張鐔告箿瑜版挸澧犲鑼剁箻閸?Operation Enabled閵? */
static void VerifyServoStateBySDO(uint8_t nodeId, const char *tag, bool expectEnabled)
{
    uint32_t modeDisplay = SDO_ReadU32(nodeId, 0x6061, 0x00);
    uint16_t statusWord  = ReadStatusWord(nodeId);
    int32_t actualSpeed  = (int32_t)SDO_ReadU32(nodeId, 0x606C, 0x00);

    LOG_INFO("%s: modeDisplay=%d status=0x%04X actualSpeed=%d\r\n",
             tag,
             (int8_t)(modeDisplay & 0xFFU),
             statusWord,
             actualSpeed);

    if (expectEnabled && !IsServoOperationEnabled(statusWord))
    {
        LOG_INFO("%s: warning, servo is not in Operation Enabled state yet\r\n", tag);
    }
}

/**
 * @brief 閹垫挸宓冩潻鎰攽閺堢喎寮芥＃鍫滀繆閹垬鈧? * @param[in] nodeId 閼哄倻鍋?ID閵? * @param[in] tag 閺冦儱绻旈弽鍥╊劮閵? */
void LogPDOFeedback(uint8_t nodeId, const char *tag)
{
